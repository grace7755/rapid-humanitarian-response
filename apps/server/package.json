{
  "name": "server",
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "postbuild": "bun ../../scripts/check-workspace-exports.ts",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun --conditions=development run --hot src/index.ts",
    "test": "bun test --conditions=development src/index.test.ts",
    "start": "bun run dist/index.mjs"
  },
  "dependencies": {
    "@my-better-t-app/api": "workspace:*",
    "@my-better-t-app/auth": "workspace:*",
    "@my-better-t-app/db": "workspace:*",
    "@my-better-t-app/env": "workspace:*",
    "@orpc/openapi": "catalog:",
    "@orpc/server": "catalog:",
    "@orpc/zod": "catalog:",
    "evlog": "^2.19.2",
    "hono": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@my-better-t-app/config": "workspace:*",
    "@types/bun": "catalog:",
    "tsdown": "^0.22.3",
    "typescript": "catalog:"
  }
}
