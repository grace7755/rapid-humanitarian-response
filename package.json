{
  "name": "my-better-t-app",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.4.2",
      "zod": "^4.4.3",
      "typescript": "^6",
      "@types/bun": "^1.3.14",
      "@types/node": "^22.13.14",
      "hono": "^4.12.27",
      "@orpc/server": "^1.14.6",
      "@orpc/openapi": "^1.14.6",
      "@orpc/zod": "^1.14.6",
      "better-auth": "1.6.23",
      "lucide-react": "^1.23.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.7",
      "react-dom": "^19.2.7",
      "sonner": "^2.0.7",
      "@orpc/client": "^1.14.6",
      "@types/react": "^19.2.17",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.3.2"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "dev:web": "turbo run dev -F web",
    "dev:server": "turbo run dev -F server",
    "db:push": "turbo run db:push -F @my-better-t-app/db",
    "db:studio": "turbo run db:studio -F @my-better-t-app/db",
    "db:generate": "turbo run db:generate -F @my-better-t-app/db",
    "db:migrate": "turbo run db:migrate -F @my-better-t-app/db",
    "db:seed": "turbo run db:seed -F @my-better-t-app/db",
    "check:workspace-exports": "bun scripts/check-workspace-exports.ts",
    "check": "biome check --write .",
    "check:ci": "biome check apps/server/src apps/web/src/components apps/web/src/features apps/web/src/routes packages/api/src packages/auth/src packages/db/src packages/env/src package.json turbo.json biome.json"
  },
  "dependencies": {
    "@my-better-t-app/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@my-better-t-app/config": "workspace:*",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "lefthook": "^2.1.9",
    "turbo": "^2.10.2",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.10"
}
